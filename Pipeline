    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "from google.colab import files\n",
        "import difflib\n",
        "import re\n",
        "import unicodedata\n",
        "\n",
        "# Carregar datasets\n",
        "df_acidentes = pd.read_csv('datasets/brutos/acidentes_transito_isp.csv', sep=';')\n",
        "df_seguranca = pd.read_csv('datasets/brutos/indicadores_seguranca_isp.csv', sep=';', encoding='latin1')\n",
        "df_logradouros = pd.read_csv('datasets/brutos/logradouros_datario.csv')\n",
        "df_relacao = pd.read_csv('datasets/uteis/relacao_cisp_isp.csv', sep=';', encoding='latin1')\n",
        "df_bairros = pd.read_csv('datasets/uteis/bairros_datario.csv', sep=',')\n",
        "df_vias_score = pd.read_csv('datasets/brutos/vias_score.csv')\n",
        "\n",
        "df_vias = pd.read_csv('datasets/brutos/rede_cicloviaria_datario.csv')\n",
        "\n",
        "ANO_CORTE = 2021\n",
        "\n",
        "\n",
        "# >>> Limpeza\n",
        "\n",
        "# df_acidentes: Padronizando capitalização de logradouros\n",
        "df_acidentes['Logradouro'] = df_acidentes['Logradouro'].str.upper().str.strip()\n",
        "\n",
        "# df_acidentes: Padronizando capitalização do nome das colunas\n",
        "df_relacao.columns = (\n",
        "    df_relacao.columns\n",
        "    .str.lower()\n",
        "    .str.strip()\n",
        ")\n",
        "\n",
        "# >>> df_logradouros\n",
        "# Padronizando capitalização de logradouros\n",
        "df_logradouros['completo'] = (\n",
        "    df_logradouros['completo']\n",
        "    .str.upper()\n",
        ")\n",
        "# Padronizando capitalização de logradouros\n",
        "df_logradouros['bairro'] = (\n",
        "    df_logradouros['bairro']\n",
        "    .str.upper()\n",
        ")\n",
        "# Remove nulos e quebras de linha de todas as colunas de texto\n",
        "df_logradouros = df_logradouros.replace(r'\\n', ' ', regex=True).replace(r'\\r', ' ', regex=True)\n",
        "df_logradouros = df_logradouros.dropna(subset=['hierarquia'])\n",
        "df_logradouros = df_logradouros.dropna(subset=['completo'])\n",
        "df_logradouros = df_logradouros.dropna(subset=['velocidade_regulamentada'])\n",
        "df_logradouros = df_logradouros[df_logradouros['velocidade_regulamentada'] > 0]\n",
        "df_logradouros = df_logradouros[~df_logradouros['completo'].str.contains('sem nome', case=False, na=False)]\n",
        "# Tipagem\n",
        "df_logradouros['velocidade_regulamentada'] = df_logradouros['velocidade_regulamentada'].astype(int)\n",
        "# Tratamento\n",
        "# Seleção de colunas relevantes\n",
        "colunas_logradouros = ['completo', 'bairro', 'hierarquia', 'velocidade_regulamentada']\n",
        "df_logradouros = df_logradouros[colunas_logradouros].copy()\n",
        "# Padronizando nomes das colunas\n",
        "df_logradouros = df_logradouros.rename(columns={\n",
        "    'completo': 'logradouro',\n",
        "    'velocidade_regulamentada': 'velocidade_maxima',\n",
        "})\n",
        "ordem_hierarquia = {\n",
        "    'Local': 1,\n",
        "    'Coletora': 1.2,\n",
        "    'Arterial secundária': 2,\n",
        "    'Arterial primária': 2.5,\n",
        "    'Estrutural': 3\n",
        "}\n",
        "df_logradouros['nivel_hierarquia'] = (\n",
        "    df_logradouros['hierarquia']\n",
        "    .map(ordem_hierarquia)\n",
        "    .fillna(1)\n",
        ")\n",
        "# Ordenar por maior hierarquia e maior velocidade\n",
        "df_logradouros = df_logradouros.sort_values(\n",
        "    by=[\n",
        "        'bairro',\n",
        "        'logradouro',\n",
        "        'nivel_hierarquia',\n",
        "        'velocidade_maxima'\n",
        "    ],\n",
        "    ascending=[True, True, False, False]\n",
        ")\n",
        "# Remover duplicatas mantendo a com o risco mais alto\n",
        "df_logradouros = (\n",
        "    df_logradouros\n",
        "    .drop_duplicates(\n",
        "        subset=['bairro', 'logradouro'],\n",
        "        keep='first'\n",
        "    )\n",
        ")\n",
        "\n",
        "\n",
        "# df_acidentes: Padronizando nomes das colunas\n",
        "df_acidentes = df_acidentes.rename(columns={\n",
        "    'Ano': 'ano',\n",
        "    'Logradouro': 'logradouro',\n",
        "    'Delito': 'delito',\n",
        "    'Total': 'total',\n",
        "})\n",
        "\n",
        "\n",
        "# df_acidentes: Filtro de ano corte\n",
        "df_acidentes = df_acidentes[df_acidentes['ano'] >= ANO_CORTE].copy()\n",
        "\n",
        "# >>> df_bairros\n",
        "# Renomear a coluna 'nome' para 'bairro'\n",
        "df_bairros = df_bairros.rename(columns={'nome': 'bairro'})\n",
        "df_bairros = df_bairros[['bairro']]\n",
        "# Garantir que os nomes estejam em maiúsculas e sem espaços extras\n",
        "df_bairros['bairro'] = df_bairros['bairro'].str.upper().str.strip()\n",
        "# Remover duplicatas\n",
        "df_bairros = df_bairros.drop_duplicates()\n",
        "\n",
        "\n",
        "# df_seguranca: Seleção de colunas relevantes\n",
        "colunas_seguranca = ['ano', 'risp', 'aisp', 'cisp', 'roubo_bicicleta', 'furto_bicicleta']\n",
        "df_seguranca = df_seguranca[colunas_seguranca].copy()\n",
        "\n",
        "# df_seguranca: Filtro de ano corte\n",
        "df_seguranca = df_seguranca[df_seguranca['ano'] >= ANO_CORTE]\n",
        "\n",
        "\n",
        "#df_relacao: Aplicando Explode na coluna \"Unidade Territorial\"\n",
        "df_relacao['unidade_limpa'] = (\n",
        "    df_relacao['unidade territorial']\n",
        "    .str.replace(r'\\(parte\\)', '', regex=True)\n",
        "    .str.strip()\n",
        ")\n",
        "df_relacao['lista_bairros'] = (\n",
        "    df_relacao['unidade_limpa']\n",
        "    .str.replace(' e ', ', ')\n",
        "    .str.split(', ')\n",
        ")\n",
        "df_relacao = df_relacao.explode('lista_bairros')\n",
        "df_relacao['bairro'] = df_relacao['lista_bairros'].str.strip()\n",
        "colunas_relacao = ['risp', 'aisp', 'cisp', 'bairro']\n",
        "df_relacao = df_relacao[colunas_relacao].copy()\n",
        "\n",
        "# >>> Tipagem\n",
        "\n",
        "# df_seguranca: Convertendo para inteiro\n",
        "df_seguranca['roubo_bicicleta'] = df_seguranca['roubo_bicicleta'].astype(int)\n",
        "df_seguranca['furto_bicicleta'] = df_seguranca['furto_bicicleta'].astype(int)\n",
        "\n",
        "\n",
        "\n",
        "# >>> Mesclagem\n",
        "\n",
        "# df_seguranca: Merge que adiciona a coluna de bairro a df_seguranca\n",
        "df_seguranca = df_seguranca.merge(\n",
        "    df_relacao,\n",
        "    on=['risp', 'aisp', 'cisp'],\n",
        "    how='left'\n",
        ")\n",
        "df_seguranca = df_seguranca.rename(\n",
        "    columns={\n",
        "        'bairro final': 'bairro'\n",
        "    }\n",
        ")\n",
        "\n",
        "# df_seguranca: Padronizando capitalização de bairros\n",
        "df_seguranca['bairro'] = (\n",
        "    df_seguranca['bairro']\n",
        "    .str.strip()\n",
        "    .str.upper()\n",
        ")\n",
        "\n",
        "# df_seguranca: Agrupando por bairro e ano para somar os acidentes\n",
        "df_seguranca = df_seguranca.groupby(['ano', 'bairro']).agg({\n",
        "    'roubo_bicicleta': 'sum',\n",
        "    'furto_bicicleta': 'sum'\n",
        "}).reset_index()\n",
        "\n",
        "\n",
        "# df_seguranca: Filtrar o df_seguranca só com bairros do município do rio\n",
        "df_seguranca = df_seguranca.merge(df_bairros, on='bairro', how='inner')\n",
        "\n",
        "\n",
        "# >>> Agregação\n",
        "\n",
        "# df_acidentes: Cria coluna que agrupa total dos acidentes por logradouro\n",
        "\n",
        "\n",
        "# df_acidentes: Cria coluna que calcula score ponderado dos acidentes\n",
        "df_acidentes = (\n",
        "    df_acidentes\n",
        "    .pivot_table(\n",
        "        index=['ano', 'logradouro'],\n",
        "        columns='delito',\n",
        "        values='total',\n",
        "        aggfunc='sum',\n",
        "        fill_value=0\n",
        "    )\n",
        "    .reset_index()\n",
        ")\n",
        "df_acidentes = df_acidentes.rename(columns={\n",
        "    'Acidente de trânsito': 'acidente',\n",
        "    'Atropelamento': 'atropelamento',\n",
        "    'Homicídio culposo - trânsito': 'homicidio_culposo',\n",
        "    'Lesão corporal culposa - trânsito': 'lesao_corporal'\n",
        "})\n",
        "df_acidentes.columns.name = None\n",
        "\n",
        "# df_acidentes: Seleção de colunas relevantes\n",
        "colunas_acidentes = ['ano', 'logradouro', 'acidente', 'atropelamento', 'homicidio_culposo', 'lesao_corporal']\n",
        "df_acidentes = df_acidentes[colunas_acidentes].copy()\n",
        "\n",
        "# df_acidentes: Mesclar com bairro\n",
        "def padronizar_rua(texto):\n",
        "    if pd.isna(texto):\n",
        "        return texto\n",
        "    texto = str(texto).upper().strip()\n",
        "\n",
        "    # Substituições comuns de abreviações\n",
        "    substituicoes = {\n",
        "        'AVENIDA ': 'AV ',\n",
        "        'AV. ': 'AV ',\n",
        "        'RUA ': 'R ',\n",
        "        'R. ': 'R ',\n",
        "        'GOVERNADOR ': '',\n",
        "        'PRESIDENTE ': '',\n",
        "        'MINISTRO ': '',\n",
        "        ' DO ': ' ',\n",
        "        ' DA ': ' ',\n",
        "        ' DE ': ' ',\n",
        "        ' DOS ': ' ',\n",
        "        ' DAS ': ' '\n",
        "    }\n",
        "\n",
        "    for chave, valor in substituicoes.items():\n",
        "        texto = texto.replace(chave, valor)\n",
        "\n",
        "    # Remove múltiplos espaços em branco que possam ter sobrado\n",
        "    texto = \" \".join(texto.split())\n",
        "    return texto\n",
        "\n",
        "# Criamos uma coluna temporária padronizada em ambas as tabelas\n",
        "df_acidentes['logra_padrao'] = df_acidentes['logradouro'].apply(padronizar_rua)\n",
        "df_logradouros['logra_padrao'] = df_logradouros['logradouro'].apply(padronizar_rua)\n",
        "\n",
        "# Fazemos o merge inicial pela coluna padronizada para adicionar o bairro\n",
        "# Atribuímos o resultado de volta a df_acidentes para que a coluna 'bairro' exista\n",
        "df_acidentes = df_acidentes.merge(\n",
        "    df_logradouros[['logra_padrao', 'bairro']].drop_duplicates(subset=['logra_padrao']),\n",
        "    on='logra_padrao',\n",
        "    how='left'\n",
        ")\n",
        "\n",
        "# Agora, identificamos os logradouros que ainda não têm bairro atribuído\n",
        "mask_sem_bairro = df_acidentes['bairro'].isna()\n",
        "sem_bairro_df = df_acidentes[mask_sem_bairro].copy() # Renamed to avoid confusion with the function\n",
        "\n",
        "# Apenas se houver logradouros sem bairro para tentar corrigir\n",
        "if not sem_bairro_df.empty:\n",
        "    logradouros_validos = df_logradouros['logra_padrao'].unique().tolist()\n",
        "\n",
        "    # Função para achar o \"vizinho mais próximo\" (already defined, but good to ensure context)\n",
        "    def busca_aproximada(rua, escolhas):\n",
        "      # n=1 (pega o melhor), cutoff=0.8 (80% de similaridade para ser seguro)\n",
        "      matches = difflib.get_close_matches(rua, escolhas, n=1, cutoff=0.8)\n",
        "      return matches[0] if matches else None\n",
        "\n",
        "    # Aplica a busca aproximada nos logradouros sem bairro\n",
        "    dicionario_ajuste = {rua: busca_aproximada(rua, logradouros_validos) for rua in sem_bairro_df['logra_padrao'].unique()}\n",
        "\n",
        "    # Atualiza 'logra_padrao' em df_acidentes para os que encontraram um match aproximado\n",
        "    # Apenas para as linhas que estavam sem bairro e agora têm um ajuste\n",
        "    adjusted_logra_padrao_map = {k:v for k,v in dicionario_ajuste.items() if v is not None}\n",
        "    df_acidentes.loc[mask_sem_bairro, 'logra_padrao'] = df_acidentes.loc[mask_sem_bairro, 'logra_padrao'].map(adjusted_logra_padrao_map)\n",
        "\n",
        "    # Preenche os bairros para os logradouros que agora têm um 'logra_padrao' corrigido\n",
        "    bairro_map_for_corrected_logras = df_logradouros.drop_duplicates(subset=['logra_padrao']).set_index('logra_padrao')['bairro']\n",
        "    df_acidentes.loc[mask_sem_bairro, 'bairro'] = df_acidentes.loc[mask_sem_bairro, 'logra_padrao'].map(bairro_map_for_corrected_logras)\n",
        "\n",
        "# Podemos descartar a coluna temporária 'logra_padrao' depois que o bairro foi totalmente preenchido\n",
        "df_acidentes = df_acidentes.drop(columns=['logra_padrao'])\n",
        "df_logradouros = df_logradouros.drop(columns=['logra_padrao'])\n",
        "\n",
        "# Descarta os sem bairro\n",
        "df_acidentes = df_acidentes.dropna(subset=['bairro'])\n",
        "\n",
        "# Criar coluna do total de acidentes\n",
        "colunas_soma_acidentes = ['acidente', 'atropelamento', 'homicidio_culposo', 'lesao_corporal']\n",
        "df_acidentes['total_delitos'] = df_acidentes[colunas_soma_acidentes].sum(axis=1)\n",
        "\n",
        "nova_ordem = ['ano', 'logradouro', 'bairro', 'acidente', 'atropelamento', 'homicidio_culposo', 'lesao_corporal', 'total_delitos']\n",
        "df_acidentes = df_acidentes[nova_ordem]\n",
        "\n",
        "# Criar coluna do total de roubos\n",
        "colunas_soma_roubos = ['roubo_bicicleta', 'furto_bicicleta']\n",
        "df_seguranca['total_crimes'] = df_seguranca[colunas_soma_roubos].sum(axis=1)\n",
        "\n",
        "# VIAS (SUBSTITUIR DEPOIS PELO OUTRO CODIGO)\n",
        "# df_vias: Padronizando capitalização de vias\n",
        "df_vias['vias'] = df_vias['vias'].str.upper().str.strip()\n",
        "df_vias['rp'] = df_vias['rp'].str.upper().str.strip()\n",
        "\n",
        "# df_vias: Padronizando nomes das colunas\n",
        "df_vias = df_vias.rename(columns={\n",
        "    'tipo_infra': 'infra_tipo',\n",
        "    'fluxo_infr': 'infra_fluxo',\n",
        "    'SHAPE__Length': 'extensao_metros',\n",
        "    'area_plane': 'area_planejamento',\n",
        "    'rp': 'bairro'\n",
        "})\n",
        "\n",
        "# df_vias: Seleção de colunas relevantes\n",
        "colunas_vias = ['infra_tipo', 'infra_fluxo', 'vias', 'inicio', 'final', 'bairro', 'extensao_metros', 'area_planejamento']\n",
        "df_vias = df_vias[colunas_vias].copy()\n",
        "\n",
        "# >>> Cálculos base para o Score de Risco\n",
        "\n",
        "# Delitos de trânsito\n",
        "# D = 1A + 5T + 10H + 3L\n",
        "# A = acidente\n",
        "# T = atropelamento\n",
        "# H = homicídio culposo\n",
        "# L = lesão corporal\n",
        "\n",
        "df_acidentes['score_d'] = (\n",
        "    1  * df_acidentes['acidente'] +\n",
        "    5  * df_acidentes['atropelamento'] +\n",
        "    10 * df_acidentes['homicidio_culposo'] +\n",
        "    3  * df_acidentes['lesao_corporal']\n",
        ")\n",
        "\n",
        "# Crimes contra ciclistas\n",
        "# C = 4R + 2F\n",
        "# R = roubo de bicicleta\n",
        "# F = furto de bicicleta\n",
        "\n",
        "df_seguranca['score_c'] = (\n",
        "    4 * df_seguranca['roubo_bicicleta'] +\n",
        "    2 * df_seguranca['furto_bicicleta']\n",
        ")\n",
        "\n",
        "# Peso velocidade\n",
        "def calcular_peso_velocidade(v):\n",
        "\n",
        "    if pd.isna(v):\n",
        "        return 1\n",
        "\n",
        "    elif v >= 70:\n",
        "        return 3\n",
        "\n",
        "    elif v >= 60:\n",
        "        return 2\n",
        "\n",
        "    elif v >= 50:\n",
        "        return 1.5\n",
        "\n",
        "    elif v >= 40:\n",
        "        return 1.2\n",
        "\n",
        "    else:\n",
        "        return 1\n",
        "\n",
        "df_logradouros['peso_v'] = (\n",
        "    df_logradouros['velocidade_maxima']\n",
        "    .apply(calcular_peso_velocidade)\n",
        ")\n",
        "df_logradouros = df_logradouros.rename(columns={\n",
        "    'nivel_hierarquia': 'peso_h'\n",
        "})\n",
        "\n",
        "# Desconsiderando 2026 (dados incompletos)\n",
        "df_seguranca_completo = (\n",
        "    df_seguranca[df_seguranca['ano'] < 2026]\n",
        ")\n",
        "\n",
        "# Fazendo a média do score_c dos anos restantes\n",
        "df_seguranca = (\n",
        "    df_seguranca_completo\n",
        "    .groupby('bairro', as_index=False)\n",
        "    .agg({\n",
        "        'score_c': 'mean'\n",
        "    })\n",
        ")\n",
        "\n",
        "df_seguranca['score_c'] = (\n",
        "    df_seguranca['score_c']\n",
        "    .round(1)\n",
        ")\n",
        "\n",
        "# Fazendo a média do score_d dos logradouros por bairro\n",
        "df_acidentes = (\n",
        "    df_acidentes\n",
        "    .groupby('bairro', as_index=False)\n",
        "    .agg({\n",
        "        'score_d': 'mean'\n",
        "    })\n",
        ")\n",
        "\n",
        "df_acidentes['score_d'] = (\n",
        "    df_acidentes['score_d']\n",
        "    .round(1)\n",
        ")\n",
        "\n",
        "\n",
        "# Fórmula\n",
        "# score_d * score_c * peso_v * peso_h * Si\n",
        "# score_d -> Delitos\n",
        "# score_d -> Crimes\n",
        "# Pv -> Peso de velocidade\n",
        "# Ph -> Peso de hierarquia\n",
        "# Si -> Score de infraestrutura\n",
        "\n",
        "\n",
        "\n",
        "# Merges finais\n",
        "\n",
        "\n",
        "df_final = df_vias.merge(\n",
        "    df_seguranca[['bairro', 'score_c']],\n",
        "    on='bairro',\n",
        "    how='left'\n",
        ")\n",
        "\n",
        "df_final = df_final.merge(\n",
        "    df_acidentes[['bairro', 'score_d']],\n",
        "    on='bairro',\n",
        "    how='left'\n",
        ")\n",
        "\n",
        "# scores vazios viram 0\n",
        "df_final['score_c'] = (\n",
        "    df_final['score_c']\n",
        "    .fillna(0)\n",
        ")\n",
        "df_final['score_d'] = (\n",
        "    df_final['score_d']\n",
        "    .fillna(0)\n",
        ")\n",
        "\n",
        "import difflib\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 1. PADRONIZAR NOMES\n",
        "# =====================================================\n",
        "df_final['via_padrao'] = (\n",
        "    df_final['vias']\n",
        "    .apply(padronizar_rua)\n",
        ")\n",
        "\n",
        "df_logradouros['logradouro_padrao'] = (\n",
        "    df_logradouros['logradouro']\n",
        "    .apply(padronizar_rua)\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 2. MERGE INICIAL (EXATO)\n",
        "# =====================================================\n",
        "df_merge = df_final.merge(\n",
        "    df_logradouros[\n",
        "        [\n",
        "            'logradouro_padrao',\n",
        "            'peso_v',\n",
        "            'peso_h'\n",
        "        ]\n",
        "    ].drop_duplicates(subset=['logradouro_padrao']),\n",
        "\n",
        "    left_on='via_padrao',\n",
        "    right_on='logradouro_padrao',\n",
        "    how='left'\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 3. IDENTIFICAR OS QUE NÃO ENCONTRARAM MATCH\n",
        "# =====================================================\n",
        "mask_sem_match = (\n",
        "    df_merge['peso_v'].isna()\n",
        ")\n",
        "\n",
        "sem_match_df = (\n",
        "    df_merge[mask_sem_match]\n",
        "    .copy()\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 4. LISTA DE LOGRADOUROS VÁLIDOS\n",
        "# =====================================================\n",
        "logradouros_validos = (\n",
        "    df_logradouros['logradouro_padrao']\n",
        "    .dropna()\n",
        "    .unique()\n",
        "    .tolist()\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 5. FUNÇÃO DE BUSCA APROXIMADA\n",
        "# =====================================================\n",
        "def busca_aproximada(nome, escolhas):\n",
        "\n",
        "    matches = difflib.get_close_matches(\n",
        "        nome,\n",
        "        escolhas,\n",
        "        n=1,\n",
        "        cutoff=0.85\n",
        "    )\n",
        "\n",
        "    return matches[0] if matches else None\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 6. CRIAR DICIONÁRIO DE AJUSTES\n",
        "# =====================================================\n",
        "dicionario_ajuste = {\n",
        "\n",
        "    rua: busca_aproximada(\n",
        "        rua,\n",
        "        logradouros_validos\n",
        "    )\n",
        "\n",
        "    for rua in sem_match_df['via_padrao'].unique()\n",
        "}\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 7. APLICAR MATCH APROXIMADO\n",
        "# =====================================================\n",
        "mapa_ajustes = {\n",
        "    k: v\n",
        "    for k, v in dicionario_ajuste.items()\n",
        "    if v is not None\n",
        "}\n",
        "\n",
        "df_merge.loc[\n",
        "    mask_sem_match,\n",
        "    'via_padrao'\n",
        "] = (\n",
        "    df_merge.loc[\n",
        "        mask_sem_match,\n",
        "        'via_padrao'\n",
        "    ]\n",
        "    .map(\n",
        "        lambda x: mapa_ajustes.get(x, x)\n",
        "    )\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 8. REFAZER O MERGE DOS NÃO ENCONTRADOS\n",
        "# =====================================================\n",
        "mapa_peso_v = (\n",
        "    df_logradouros\n",
        "    .drop_duplicates(subset=['logradouro_padrao'])\n",
        "    .set_index('logradouro_padrao')['peso_v']\n",
        ")\n",
        "\n",
        "mapa_peso_h = (\n",
        "    df_logradouros\n",
        "    .drop_duplicates(subset=['logradouro_padrao'])\n",
        "    .set_index('logradouro_padrao')['peso_h']\n",
        ")\n",
        "\n",
        "\n",
        "df_merge.loc[\n",
        "    mask_sem_match,\n",
        "    'peso_v'\n",
        "] = (\n",
        "    df_merge.loc[\n",
        "        mask_sem_match,\n",
        "        'via_padrao'\n",
        "    ]\n",
        "    .map(mapa_peso_v)\n",
        ")\n",
        "\n",
        "\n",
        "df_merge.loc[\n",
        "    mask_sem_match,\n",
        "    'peso_h'\n",
        "] = (\n",
        "    df_merge.loc[\n",
        "        mask_sem_match,\n",
        "        'via_padrao'\n",
        "    ]\n",
        "    .map(mapa_peso_h)\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 9. REMOVER COLUNAS TEMPORÁRIAS\n",
        "# =====================================================\n",
        "df_merge = df_merge.drop(\n",
        "    columns=[\n",
        "        'via_padrao',\n",
        "        'logradouro_padrao'\n",
        "    ],\n",
        "    errors='ignore'\n",
        ")\n",
        "\n",
        "\n",
        "# =====================================================\n",
        "# 10. RESULTADO FINAL\n",
        "# =====================================================\n",
        "df_final = df_merge.copy()\n",
        "df_vias_score.drop_duplicates(subset=['vias'], inplace=True)\n",
        "\n",
        "# MERGE COM VIAS_SCORE\n",
        "# Garantir que os nomes estejam em maiúsculas e sem espaços extras\n",
        "df_vias_score['vias'] = df_vias_score['vias'].str.upper()\n",
        "\n",
        "df_final = df_final.merge(\n",
        "\n",
        "    df_vias_score[\n",
        "        [\n",
        "            'vias',\n",
        "            'safety_score_final_v2'\n",
        "        ]\n",
        "    ],\n",
        "\n",
        "    on='vias',\n",
        "    how='left'\n",
        ")\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "df_final['peso_v'] = (\n",
        "    df_final['peso_v']\n",
        "    .fillna(1)\n",
        ")\n",
        "\n",
        "df_final['peso_h'] = (\n",
        "    df_final['peso_h']\n",
        "    .fillna(1)\n",
        ")\n",
        "\n",
        "df_final['risco_infraestrutura'] = (\n",
        "    10\n",
        "    -\n",
        "    df_final['safety_score_final_v2']\n",
        ")\n",
        "\n",
        "alpha= 0.3\n",
        "df_final['score_risco'] = np.where(\n",
        "\n",
        "    (\n",
        "        (df_final['score_c'].fillna(0) != 0)\n",
        "        |\n",
        "        (df_final['score_d'].fillna(0) != 0)\n",
        "    ),\n",
        "\n",
        "    (\n",
        "        (\n",
        "            (\n",
        "                df_final['score_c'].fillna(0)\n",
        "                +\n",
        "                df_final['score_d'].fillna(0)\n",
        "            )\n",
        "\n",
        "            *\n",
        "            df_final['peso_v'].fillna(1)\n",
        "\n",
        "            *\n",
        "            df_final['peso_h'].fillna(1)\n",
        "        )\n",
        "\n",
        "        +\n",
        "\n",
        "        df_final['risco_infraestrutura']\n",
        "    ),\n",
        "\n",
        "    (\n",
        "        (\n",
        "            df_final['peso_v'].fillna(1)\n",
        "\n",
        "            *\n",
        "\n",
        "            df_final['peso_h'].fillna(1)\n",
        "        )\n",
        "\n",
        "        +\n",
        "\n",
        "        alpha*df_final['risco_infraestrutura']\n",
        "    )\n",
        ")\n",
        "\n",
        "\n",
        "df_final['score_risco'] = (\n",
        "    df_final['score_risco']\n",
        "    .round(1)\n",
        ")\n",
        "\n",
        "df_final['risco_normalizado'] = (\n",
        "    (\n",
        "        df_final['score_risco']\n",
        "        -\n",
        "        df_final['score_risco'].min()\n",
        "    )\n",
        "    /\n",
        "    (\n",
        "        df_final['score_risco'].max()\n",
        "        -\n",
        "        df_final['score_risco'].min()\n",
        "    )\n",
        ") * 100\n",
        "\n",
        "df_final['seguranca_normalizada'] = (\n",
        "    100\n",
        "    -\n",
        "    df_final['risco_normalizado']\n",
        ")\n",
        "\n",
        "def classificar_seguranca(x):\n",
        "\n",
        "    if x >= 80:\n",
        "        return 'Alta segurança'\n",
        "\n",
        "    elif x >= 60:\n",
        "        return 'Segurança moderada'\n",
        "\n",
        "    elif x >= 40:\n",
        "        return 'Atenção'\n",
        "\n",
        "    elif x >= 20:\n",
        "        return 'Baixa segurança'\n",
        "\n",
        "    else:\n",
        "        return 'Muito perigoso'\n",
        "\n",
        "\n",
        "df_final['categoria_seguranca'] = (\n",
        "    df_final['seguranca_normalizada']\n",
        "    .apply(classificar_seguranca)\n",
        ")\n",
        "\n",
        "mapa_cores = {\n",
        "    'Alta segurança': 'verde',\n",
        "    'Segurança moderada': 'verde claro',\n",
        "    'Atenção': 'amarelo',\n",
        "    'Baixa segurança': 'laranja',\n",
        "    'Muito perigoso': 'vermelho'\n",
        "}\n",
        "\n",
        "df_final['cor'] = (\n",
        "    df_final['categoria_seguranca']\n",
        "    .map(mapa_cores)\n",
        ")\n",
        "\n",
        "df_final = df_final.drop(columns=['risco_normalizado', 'seguranca_normalizada'])\n",
        "\n",
